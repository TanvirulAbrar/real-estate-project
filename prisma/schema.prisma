
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// Enums 
enum UserRole {
  client
  agent
  admin

}

enum Theme {
  light
  dark

}

enum PropertyType {
  house
  apartment
  condo
  townhouse
  land
  commercial
  other

}

enum ListingType {
  sale
  rent

}

enum PropertyStatus {
  active
  pending
  sold
  rented
  inactive

}

enum InquiryStatus {
  new
  read
  responded
  closed

}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed

}

enum OfferStatus {
  pending
  accepted
  rejected
  countered
  withdrawn

}

enum TransactionStatus {
  pending
  in_escrow
  closed
  cancelled

}

enum ReviewTargetType {
  agent
  property

}

enum NotificationType {
  inquiry_received
  offer_received
  appointment_scheduled
  appointment_confirmed
  offer_accepted
  offer_rejected
  transaction_closed
  general

}

enum ContactSubmissionStatus {
  new
  read
  resolved

}

//  Models 

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String?
  name           String?
  phone          String?
  avatar_url     String?
  bio            String?
  role           UserRole  @default(client)
  theme          Theme     @default(light)
  is_demo        Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  properties      Property[]
  inquiries       Inquiry[]    @relation("ClientInquiries")
  agentInquiries  Inquiry[]   @relation("AgentInquiries")
  favorites       Favorite[]
  reviews         Review[]
  appointments    Appointment[] @relation("ClientAppointments")
  agentAppointments Appointment[] @relation("AgentAppointments")
  offers          Offer[]
  buyerTransactions Transaction[] @relation("BuyerTransactions")
  agentTransactions Transaction[] @relation("AgentTransactions")
  notifications   Notification[]
  blogPosts       BlogPost[]
  inquiryMessages InquiryMessage[]

  @@map("users")
}

model Property {
  id            String         @id @default(uuid())
  agent_id      String
  title         String
  description   String?
  price         Decimal        @db.Decimal(12, 2)
  address       String
  city          String
  state         String
  zip_code      String
  country       String         @default("US")
  property_type PropertyType
  listing_type  ListingType
  bedrooms     Int?
  bathrooms    Decimal?       @db.Decimal(4, 1)
  area_sqft    Decimal?       @db.Decimal(10, 2)
  year_built   Int?
  status       PropertyStatus @default(active)
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  deleted_at   DateTime?

  agent         User           @relation(fields: [agent_id], references: [id])
  images        PropertyImage[]
  inquiries     Inquiry[]
  favorites     Favorite[]
  reviews       Review[]
  appointments  Appointment[]
  offers        Offer[]
  transactions  Transaction[]

  @@map("properties")
}

model PropertyImage {
  id             String   @id @default(uuid())
  property_id    String
  url            String
  is_primary     Boolean  @default(false)
  display_order Int      @default(0)
  created_at     DateTime @default(now())

  property       Property @relation(fields: [property_id], references: [id])

  @@map("property_images")
}

model Inquiry {
  id             String        @id @default(uuid())
  property_id   String
  client_id     String
  agent_id      String
  message       String
  contact_phone String?
  status        InquiryStatus @default(new)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  deleted_at    DateTime?

  property       Property      @relation(fields: [property_id], references: [id])
  client         User          @relation("ClientInquiries", fields: [client_id], references: [id])
  agent          User          @relation("AgentInquiries", fields: [agent_id], references: [id])
  messages       InquiryMessage[]

  @@map("inquiries")
}

model InquiryMessage {
  id          String   @id @default(uuid())
  inquiry_id  String
  sender_id   String
  message     String
  created_at  DateTime @default(now())

  inquiry     Inquiry  @relation(fields: [inquiry_id], references: [id])
  sender      User     @relation(fields: [sender_id], references: [id])

  @@map("inquiry_messages")
}

model Favorite {
  id          String   @id @default(uuid())
  user_id     String
  property_id String
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id])
  property    Property @relation(fields: [property_id], references: [id])

  @@unique([user_id, property_id])
  @@map("favorites")
}

model Review {
  id          String           @id @default(uuid())
  author_id   String
  target_type ReviewTargetType
  target_id   String
  rating      Int
  comment     String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  author      User             @relation(fields: [author_id], references: [id])
  property    Property?        @relation(fields: [target_id], references: [id], map: "review_property_fk")

  @@unique([author_id, target_type, target_id])
  @@map("reviews")
}

model Appointment {
  id            String            @id @default(uuid())
  property_id  String
  client_id    String
  agent_id     String
  scheduled_at DateTime
  notes        String?
  status       AppointmentStatus @default(pending)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  deleted_at   DateTime?

  property     Property          @relation(fields: [property_id], references: [id])
  client       User              @relation("ClientAppointments", fields: [client_id], references: [id])
  agent        User              @relation("AgentAppointments", fields: [agent_id], references: [id])

  @@map("appointments")
}

model Offer {
  id           String      @id @default(uuid())
  property_id  String
  buyer_id     String
  amount       Decimal     @db.Decimal(12, 2)
  message      String?
  expiry_date  DateTime
  status       OfferStatus @default(pending)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
  deleted_at   DateTime?

  property     Property    @relation(fields: [property_id], references: [id])
  buyer        User        @relation(fields: [buyer_id], references: [id])
  transaction  Transaction?

  @@map("offers")
}

model Transaction {
  id              String            @id @default(uuid())
  property_id     String
  buyer_id        String
  agent_id        String
  offer_id        String?           @unique
  sale_price      Decimal           @db.Decimal(12, 2)
  commission_rate Decimal           @db.Decimal(5, 2)
  closing_date    DateTime?
  status          TransactionStatus @default(pending)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  property        Property          @relation(fields: [property_id], references: [id])
  buyer           User              @relation("BuyerTransactions", fields: [buyer_id], references: [id])
  agent           User              @relation("AgentTransactions", fields: [agent_id], references: [id])
  offer           Offer?            @relation(fields: [offer_id], references: [id])

  @@map("transactions")
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String
  type       NotificationType
  title      String
  body       String
  is_read    Boolean          @default(false)
  related_id String?
  created_at DateTime         @default(now())

  user       User             @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model BlogPost {
  id              String    @id @default(uuid())
  author_id       String
  title           String
  content         String
  excerpt         String?
  cover_image_url String?
  tags            String[]
  published_at    DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  author          User      @relation(fields: [author_id], references: [id])

  @@map("blog_posts")
}

model ContactSubmission {
  id           String                  @id @default(uuid())
  name         String
  email        String
  subject      String
  message      String
  status       ContactSubmissionStatus @default(new)
  submitted_at DateTime                @default(now())
  updated_at   DateTime                @updatedAt

  @@map("contact_submissions")
}
